{
  "source": {
    "include": ["src/app"],
    "includePattern": ".+\\.(js|ts)$",
    "excludePattern": "(node_modules|docs|dist)"
  },
  "sourceType": "module",
  "tags": {
    "allowUnknownTags": true,
    "dictionaries": ["jsdoc", "closure"]
  },
  "opts": {
    "destination": "./docs",
    "recurse": true,
    "readme": "README.md",
    "template": "node_modules/jsdoc/templates/default"
  },
  "plugins": [],
  "templates": {
    "cleverLinks": false,
    "monospaceLinks": false
  }
}
